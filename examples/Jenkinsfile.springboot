@Library('devops-shared-lib') _

pipeline {
    agent any

    environment {
        DOCKER_CREDENTIALS_ID = 'dockerhub-creds'
        SONAR_SERVER = 'sonarqube-server'
        IMAGE_BASE = 'springboot-app'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean test package'
            }
        }

        stage('SCA Scan') {
            steps {
                owasp_dependency()
            }
        }

        stage('SonarQube Analysis') {
            steps {
                sonarqube_analysis(
                    ServerName: env.SONAR_SERVER,
                    ProjectName: env.JOB_NAME,
                    ProjectKey: env.JOB_NAME.replaceAll('/', '-')
                )
            }
        }

        stage('Quality Gate') {
            steps {
                sonarqube_code_quality(TimeoutMinutes: 3, AbortPipeline: true)
            }
        }

        stage('Docker Build and Scan') {
            steps {
                docker_build_and_scan(
                    CredId: env.DOCKER_CREDENTIALS_ID,
                    ImageBase: env.IMAGE_BASE,
                    Tags: [env.BUILD_NUMBER, 'latest'],
                    ContextPath: '.',
                    Severities: ['HIGH', 'CRITICAL']
                )
            }
        }

        stage('Generate SBOM') {
            steps {
                generate_sbom(Target: '.', Type: 'fs')
            }
        }

        stage('Push Image') {
            when {
                branch 'main'
            }
            steps {
                docker_push(
                    CredId: env.DOCKER_CREDENTIALS_ID,
                    ImageBase: env.IMAGE_BASE,
                    Tags: [env.BUILD_NUMBER, 'latest']
                )
            }
        }

        stage('GenAI Release Summary') {
            when {
                expression { return env.GENAI_ENABLED == 'true' }
            }
            steps {
                genai_release_notes(
                    CredentialsId: 'genai-api-token',
                    Model: 'gpt-4o-mini',
                    CommitLimit: 10
                )
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'reports/**', allowEmptyArchive: true
        }
    }
}
